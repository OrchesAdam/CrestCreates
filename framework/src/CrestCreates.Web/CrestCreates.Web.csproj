    <ProjectReference Include="..\CrestCreates.AspNetCore\CrestCreates.AspNetCore.csproj" />
    <ProjectReference Include="..\CrestCreates.AspNetCore.Authentication.JwtBearer\CrestCreates.AspNetCore.Authentication.JwtBearer.csproj" />
    <ProjectReference Include="..\CrestCreates.Authorization\CrestCreates.Authorization.csproj" />
    <ProjectReference Include="..\CrestCreates.Infrastructure\CrestCreates.Infrastructure.csproj" />
    <ProjectReference Include="..\CrestCreates.Logging\CrestCreates.Logging.csproj" />
    <ProjectReference Include="..\CrestCreates.AuditLogging\CrestCreates.AuditLogging.csproj" />
    <ProjectReference Include="..\CrestCreates.Domain\CrestCreates.Domain.csproj" />
    <ProjectReference Include="..\CrestCreates.Domain.Shared\CrestCreates.Domain.Shared.csproj" />
    <ProjectReference Include="..\CrestCreates.MultiTenancy.Abstract\CrestCreates.MultiTenancy.Abstract.csproj" />
