<Project>
  <UsingTask TaskName="CrestCreates.BuildTasks.ScanModulesFromSource" AssemblyFile="$(MSBuildThisFileDirectory)CrestCreates.BuildTasks.dll" />
  <UsingTask TaskName="CrestCreates.BuildTasks.CollectModuleManifests" AssemblyFile="$(MSBuildThisFileDirectory)CrestCreates.BuildTasks.dll" />
  <UsingTask TaskName="CrestCreates.BuildTasks.GenerateAggregatedModuleCode" AssemblyFile="$(MSBuildThisFileDirectory)CrestCreates.BuildTasks.dll" />
  <UsingTask TaskName="CrestCreates.BuildTasks.ScanEntityPermissions" AssemblyFile="$(MSBuildThisFileDirectory)CrestCreates.BuildTasks.dll" />

  <PropertyGroup>
    <EnableModuleManifestGeneration Condition="'$(EnableModuleManifestGeneration)' == ''">true</EnableModuleManifestGeneration>
    <ModuleManifestOutputPath Condition="'$(ModuleManifestOutputPath)' == ''">$(IntermediateOutputPath)ModuleManifest.json</ModuleManifestOutputPath>
    <EnableEntityPermissionsScan Condition="'$(EnableEntityPermissionsScan)' == ''">true</EnableEntityPermissionsScan>
    <EntityPermissionsManifestOutputPath Condition="'$(EntityPermissionsManifestOutputPath)' == ''">$(IntermediateOutputPath)EntityPermissionsManifest.json</EntityPermissionsManifestOutputPath>
  </PropertyGroup>

  <Target Name="GenerateModuleManifest"
          BeforeTargets="BeforeBuild"
          Condition="'$(EnableModuleManifestGeneration)' == 'true'">

    <PropertyGroup>
      <_ModuleSourceFiles>@(Compile->'%(FullPath)')</_ModuleSourceFiles>
    </PropertyGroup>

    <ScanModulesFromSource
      SourceFiles="$(_ModuleSourceFiles)"
      OutputPath="$(ModuleManifestOutputPath)" />

    <Message Text="Generated module manifest: $(ModuleManifestOutputPath)" Importance="high" />
  </Target>

  <Target Name="ScanEntityPermissions"
          AfterTargets="Build"
          Condition="'$(EnableEntityPermissionsScan)' == 'true'">

    <ItemGroup>
      <_EntityPermissionSourceFiles Include="@(Compile->'%(FullPath)')" />
      <_EntityPermissionSourceFiles Include="$(CompilerGeneratedFilesOutputPath)\**\*Permissions.g.cs" Condition="'$(CompilerGeneratedFilesOutputPath)' != ''" />
      <_EntityPermissionSourceFiles Include="$(IntermediateOutputPath)generated\**\*Permissions.g.cs" />
    </ItemGroup>

    <ScanEntityPermissions
      SourceFiles="@(_EntityPermissionSourceFiles)"
      OutputPath="$(EntityPermissionsManifestOutputPath)" />

    <Copy SourceFiles="$(EntityPermissionsManifestOutputPath)"
          DestinationFolder="$(OutputPath)"
          Condition="Exists('$(EntityPermissionsManifestOutputPath)')" />

    <ItemGroup Condition="Exists('$(EntityPermissionsManifestOutputPath)')">
      <Content Include="$(EntityPermissionsManifestOutputPath)"
               Link="EntityPermissionsManifest.json"
               CopyToOutputDirectory="PreserveNewest"
               CopyToPublishDirectory="PreserveNewest" />
    </ItemGroup>

    <Message Text="Generated entity permissions manifest: $(EntityPermissionsManifestOutputPath)" Importance="high" />
  </Target>

</Project>
