<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>CrestCreates.CodeGenerator.Tests</RootNamespace>
    <AssemblyName>CrestCreates.CodeGenerator.Tests</AssemblyName>
    <OutputType>Library</OutputType>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <!-- 禁用自动生成程序集信息以避免冲突 -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <!-- 启用源代码生成器文件输出 -->
    <EmitCompilerGeneratedFiles>false</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>
  <ItemGroup>
    <!-- 引用CodeGenerator作为分析器 -->
    <ProjectReference Include="..\..\tools\CrestCreates.CodeGenerator\CrestCreates.CodeGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    
    <!-- 项目引用 -->
    <ProjectReference Include="..\..\src\CrestCreates.Domain.Shared\CrestCreates.Domain.Shared.csproj" />
    <ProjectReference Include="..\..\src\CrestCreates.Domain\CrestCreates.Domain.csproj" />
    <ProjectReference Include="..\..\src\CrestCreates.Infrastructure\CrestCreates.Infrastructure.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- 包引用 -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Moq" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="FreeSql" />
    <PackageReference Include="SqlSugarCore" />
  </ItemGroup>
  
<!--  &lt;!&ndash; 排除 Entities 和 Services 文件夹，避免触发代码生成 &ndash;&gt;-->
<!--  <ItemGroup>-->
<!--    <Compile Remove="Entities\**\*.cs" />-->
<!--    <Compile Remove="Services\**\*.cs" />-->
<!--  </ItemGroup>-->

</Project>
