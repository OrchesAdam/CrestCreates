<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>CrestCreates.CodeGenerator.Tests</RootNamespace>
    <AssemblyName>CrestCreates.CodeGenerator.Tests</AssemblyName>
    <OutputType>Library</OutputType>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);NU1510</NoWarn>
    <!-- 禁用自动生成程序集信息以避免冲突 -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <!-- 启用源代码生成器文件输出，以便查看生成的文件 -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
  </PropertyGroup>
  <ItemGroup>
    <!-- 引用CodeGenerator作为分析器 -->
    
    <!-- 同时引用CodeGenerator作为常规项目，以便测试代码可以访问生成器类型 -->
    <ProjectReference Include="..\..\tools\CrestCreates.CodeGenerator\CrestCreates.CodeGenerator.csproj" />
    
    <!-- 项目引用 -->
    <ProjectReference Include="..\..\src\CrestCreates.Domain.Shared\CrestCreates.Domain.Shared.csproj" />
    <ProjectReference Include="..\..\src\CrestCreates.Domain\CrestCreates.Domain.csproj" />
    <ProjectReference Include="..\..\src\CrestCreates.Application\CrestCreates.Application.csproj" />
    <ProjectReference Include="..\..\src\CrestCreates.Infrastructure\CrestCreates.Infrastructure.csproj" />
    <ProjectReference Include="..\..\src\CrestCreates.Modularity\CrestCreates.Modularity.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- 包引用 -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Moq" />
    <PackageReference Include="FluentAssertions" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="FreeSql" />
    <PackageReference Include="SqlSugarCore" />
  </ItemGroup>
  
<!--  &lt;!&ndash; 排除 Entities 和 Services 文件夹，避免触发代码生成 &ndash;&gt;-->
<!--  <ItemGroup>-->
<!--    <Compile Remove="Entities\**\*.cs" />-->
<!--    <Compile Remove="Services\**\*.cs" />-->
<!--  </ItemGroup>-->

</Project>
