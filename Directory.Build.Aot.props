<Project>
  <!-- AoT 编译支持配置 (仅适用于 net10.0+ 项目，排除 netstandard2.0 的 CodeGenerator) -->
  <PropertyGroup Condition="$(TargetFramework) != 'netstandard2.0'">
    <!-- 启用 AoT 编译 -->
    <PublishAot>true</PublishAot>
    <TrimMode>partial</TrimMode>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>

    <!-- 优化配置 -->
    <Optimize>true</Optimize>
    <DebugType>pdbonly</DebugType>
    <DebugSymbols>true</DebugSymbols>

    <!-- 运行时标识符 -->
    <RuntimeIdentifiers>win-x64;linux-x64;osx-x64</RuntimeIdentifiers>
  </PropertyGroup>

  <!-- 配置修剪行为 -->
  <ItemGroup Condition="$(TargetFramework) != 'netstandard2.0'">
    <!-- 保留必要的类型和成员 -->
    <TrimmerRootAssembly Include="CrestCreates.Domain" />
    <TrimmerRootAssembly Include="CrestCreates.Infrastructure" />
    <TrimmerRootAssembly Include="CrestCreates.Web" />
  </ItemGroup>

  <!-- 全局 Source Generator (Analyzer) 引用 -->
  <ItemGroup>
    <ProjectReference Include="$(MSBuildThisFileDirectory)framework\tools\CrestCreates.CodeGenerator\CrestCreates.CodeGenerator.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"
                      Condition="$(MSBuildProjectName) != 'CrestCreates.CodeGenerator'" />
  </ItemGroup>

  <!-- 为特定项目添加 AoT 配置 -->
  <Target Name="ConfigureAotForWeb" BeforeTargets="Build" Condition="$(MSBuildProjectName.Contains('Web'))">
    <PropertyGroup>
      <PublishAot>true</PublishAot>
      <TrimMode>partial</TrimMode>
    </PropertyGroup>
  </Target>
</Project>
