{
  "ConnectionStrings": {
    "Default": "Server=(localdb)\\mssqllocaldb;Database=LibraryManagement;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CrestLogging": {
    "MinimumLevel": "Information",
    "EnableConsole": true,
    "EnableFile": true,
    "FilePath": "logs/librarymanagement-.txt",
    "Overrides": {
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AuditLogging": {
    "IsEnabled": true,
    "IsEnabledForGetRequests": false,
    "IncludeRequestBody": true,
    "IncludeResponseBody": false,
    "HideErrors": true
  },
  "AllowedHosts": "*"
}
