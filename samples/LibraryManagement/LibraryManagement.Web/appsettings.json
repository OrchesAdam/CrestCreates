{
  "ConnectionStrings": {
    "Default": "Server=(localdb)\\mssqllocaldb;Database=LibraryManagement;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CrestLogging": {
    "MinimumLevel": "Information",
    "EnableConsole": true,
    "EnableFile": true,
    "FilePath": "logs/librarymanagement-.txt",
    "Overrides": {
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AuditLogging": {
    "IsEnabled": true,
    "IsEnabledForGetRequests": false,
    "IncludeRequestBody": true,
    "IncludeResponseBody": false,
    "HideErrors": true
  },
  "Jwt": {
    "SecretKey": "LibraryManagementSampleSecretKey123!",
    "Issuer": "LibraryManagement.Sample",
    "Audience": "LibraryManagement.Sample",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Identity": {
    "MinPasswordLength": 8,
    "RequireDigit": true,
    "RequireLowercase": true,
    "RequireUppercase": true,
    "RequireNonAlphanumeric": true,
    "MaxAccessFailedCount": 5,
    "LockoutMinutes": 15
  },
  "SeedIdentity": {
    "TenantId": "host",
    "RoleName": "Administrators",
    "UserName": "admin",
    "Email": "admin@library.local",
    "Password": "Admin123!"
  },
  "AllowedHosts": "*"
}
