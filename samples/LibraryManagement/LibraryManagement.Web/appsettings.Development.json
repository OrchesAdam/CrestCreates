{
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=librarymanagement;Username=crest;Password=crest123"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "CrestLogging": {
    "MinimumLevel": "Debug",
    "EnableConsole": true,
    "EnableFile": true,
    "FilePath": "logs/librarymanagement-dev-.txt",
    "Overrides": {
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Jwt": {
    "SecretKey": "LibraryManagementSampleSecretKey123!",
    "Issuer": "LibraryManagement.Sample",
    "Audience": "LibraryManagement.Sample",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Identity": {
    "MinPasswordLength": 8,
    "RequireDigit": true,
    "RequireLowercase": true,
    "RequireUppercase": true,
    "RequireNonAlphanumeric": true,
    "MaxAccessFailedCount": 5,
    "LockoutMinutes": 15
  },
  "SeedIdentity": {
    "TenantId": "host",
    "RoleName": "Administrators",
    "UserName": "admin",
    "Email": "admin@library.local",
    "Password": "Admin123!"
  }
}
