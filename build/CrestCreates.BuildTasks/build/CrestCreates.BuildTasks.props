<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  
  <!-- 
    CrestCreates Build Tasks Props File
    This file is automatically imported when the NuGet package is installed
  -->
  
  <PropertyGroup>
    <!-- Enable module manifest generation by default -->
    <EnableModuleManifestGeneration Condition="'$(EnableModuleManifestGeneration)' == ''">true</EnableModuleManifestGeneration>
    
    <!-- Default output paths -->
    <ModuleManifestOutputPath Condition="'$(ModuleManifestOutputPath)' == ''">$(MSBuildProjectDirectory)\obj\$(Configuration)\$(TargetFramework)\ModuleManifest.json</ModuleManifestOutputPath>
    <AggregatedModuleManifestPath Condition="'$(AggregatedModuleManifestPath)' == ''">$(MSBuildProjectDirectory)\obj\$(Configuration)\$(TargetFramework)\AggregatedModuleManifest.json</AggregatedModuleManifestPath>
    <AggregatedModuleCodePath Condition="'$(AggregatedModuleCodePath)' == ''">$(MSBuildProjectDirectory)\obj\$(Configuration)\$(TargetFramework)\ModuleAutoInitializer.g.cs</AggregatedModuleCodePath>

    <EnableEntityPermissionsScan Condition="'$(EnableEntityPermissionsScan)' == ''">true</EnableEntityPermissionsScan>
    <EntityPermissionsManifestOutputPath Condition="'$(EntityPermissionsManifestOutputPath)' == ''">$(MSBuildProjectDirectory)\obj\$(Configuration)\$(TargetFramework)\EntityPermissionsManifest.json</EntityPermissionsManifestOutputPath>
  </PropertyGroup>
  
</Project>
